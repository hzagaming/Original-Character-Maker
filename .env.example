# Original Character Maker - Environment Configuration
# Copy this file to .env and fill in your API keys.

# Server port (local development)
PORT=3001

# Plato API (image generation / expression / CG)
PLATO_API_KEY=
PLATO_BASE_URL=https://api.bltcy.ai/v1

# Provider configuration
EXPRESSION_PROVIDER=plato
CG_PROVIDER=plato

# Pipeline mode: live | mock
PIPELINE_MODE=live

# CORS origin for local development
CORS_ORIGIN=*

# Maximum upload size (10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

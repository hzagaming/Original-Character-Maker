PORT=3001
NODE_ENV=development
CORS_ORIGIN=*
MAX_UPLOAD_SIZE_BYTES=10485760
MIN_IMAGE_WIDTH=256
MIN_IMAGE_HEIGHT=256
IMAGE_GEN_CONCURRENCY=2

# 工作流模式: mock | live
PIPELINE_MODE=mock

# 背景移除 Provider: rembg | frontend | aliyun | banana2 | mock
# rembg: Python 本地 AI 推理（默认，无需 API Key）
# frontend: 浏览器 Canvas 抠图（需前端上传）
# aliyun: 阿里云图像分割（需配置 Access Key）
# banana2: Banana2 API 通道
# mock: 模拟数据，不执行真实抠图
BG_REMOVAL_PROVIDER=rembg

# 阿里云图像分割配置（当 BG_REMOVAL_PROVIDER=aliyun 时使用）
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIYUN_IMAGESEG_ENDPOINT=imageseg.cn-shanghai.aliyuncs.com
# ALIYUN_IMAGESEG_REGION_ID=cn-shanghai
# ALIYUN_IMAGESEG_ACTION=SegmentCommonImage
# ALIYUN_IMAGESEG_RETURN_FORM=
# ALIYUN_IMAGESEG_TIMEOUT_MS=120000

# 前端抠图运行时资源地址
CUTOUT_ASSET_BASE_URL=https://staticimgly.com/@imgly/background-removal-data/1.7.0/dist

# 表情生成 Provider: mock | plato | banana2
EXPRESSION_PROVIDER=mock

# 表情生成是否强制白色背景（默认 false，即允许带背景生成更精致的图像）
# 设为 true 时会在 prompt 末尾追加「图片背景纯白，同时画面中不要有任何除人物外的东西」
# EXPRESSION_WHITE_BACKGROUND=true

# CG 生成 Provider: mock | plato | banana2
CG_PROVIDER=mock

# Plato API（图像生成）
PLATO_API_KEY=
PLATO_BASE_URL=https://api.bltcy.ai/v1
PLATO_MODEL=gemini-3.1-flash-image-preview
PLATO_TIMEOUT_MS=120000
# PLATO_MODEL_FALLBACKS=
# PLATO_IMAGE_EDIT_MODELS=

# Banana2 API（备用）
BANANA2_API_KEY=
BANANA2_BASE_URL=https://api.apiyi.com
BANANA2_MODEL=gemini-3.1-flash-image-preview
BANANA2_IMAGE_SIZE=1K
BANANA2_ASPECT_RATIO=1:1
BANANA2_TIMEOUT_MS=120000

# Provider 降级回退
# ALLOW_PROVIDER_MOCK_FALLBACK=true

# 目录配置
UPLOAD_DIR=./tmp/uploads
WORKFLOW_STATE_DIR=./tmp/workflows
OUTPUT_DIR=./tmp/outputs

# 公共应用地址（用于生成可访问的URL）
# PUBLIC_APP_BASE_URL=https://your-domain.com
